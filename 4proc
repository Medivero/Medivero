float bb(float x) {
	return sin(x)*1;
}
int main() 
{
	double const pi = 3.14;
	float niz = -2*pi;
	float verh = 2*pi;
	float g = 0.1;
	float y = 1;
	float shag = pi / 30;
	float x;
	while (y >= -1) {
		for (x = niz; x <= verh; x = x+shag) {
			if (abs(bb(x) - y) > g) {
				if (abs(y) < g) {
					cout << "-"; 
				}
				else {
					cout << " ";}
			}
			if (abs(bb(x)-y) < g) {
				cout << "/";
			}
		} 
		cout << endl;
		y = y - 0.2;
	}
}
