    if ((sys1 == 1) or (sys1 > 16)){
        cout << "Error.";
        exit(0);
    }
    if (sys1 > 9){
        for (int i = 0;i < num.size(); i++){
            char c0 = num[i];
            for (int j = 0;j < abc.size(); j++){
                if (c0 == abc[j]){
                    cout << "Error.";
                    exit(0);
                }
            }
        }
    }
    cout << "Введите систему счисления в которую хотите перевести(2-16):";
    cin >> sys2;
    if ((sys2 == 1) or (sys2 > 16)){
        cout << "Error.";
        exit(0);
    }
    int dec = fromcrrnttoten(num, sys1);
