#include <iostream>
#include <string>
#include <cmath>
#include <algorithm>
using namespace std;
string abc = "0123456789ABCDEF";
int fromcrrnttoten(string num, int sys) {

    int result = 0;
    int len = num.size();
    for (int i = 0; i < len; i++) {
        char c = num[i];
        int value = abc.find(toupper(c));
        result += value * pow(sys, len - i - 1);
    }
    return result;
}
string fromtentoneed(int num, int sys) {
    string result;
    while (num > 0) {
        int rem = num % sys;
        result = abc[rem] + result;
        num /= sys;
    }
    return result;
}
int main() {
    setlocale(0, "");
    string num;
    int sys1, sys2;
    cout << "Введите число:";
    cin >> num;
    cout << "Введите изначальную систему счисления (2-16):";
