#include <iostream>
#include <cmath>
using namespace std;
int main(){
    double S,m,n,p,mt,r;
    double rt = 0.0001;
    cout << "S:";
    cin >> S;
    cout << "m:";
    cin >> m;
    cout << "n:";
    cin >> n;
    if (n == 0 or S<=0){
        cout << "Error.";
        main();
    }
    while (mt < m){
        r = rt;
        m = S*r*pow(1+r,n)/(12*(pow(1+r,n)-1));
        rt = rt+0.0001;
    }
    cout << "p:" << r*100;
}
